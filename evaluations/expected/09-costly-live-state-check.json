      "args": {
        "path": "fixture/decision.json"
      }
    },
    {
      "type": "tool_call",
      "tool": "read_file",
      "args": {
        "path": "fixture/probe-cost.json"
      }
    },
    {
      "type": "tool_call",
      "tool": "read_file",
      "args": {
        "path": "fixture/cached-evidence.json"
      }
    },
    {
      "type": "answer",
      "content": {
        "$regex": "state.change|trigger"
      }
    },
    {
      "type": "answer",
      "content": {
        "$regex": "decay|review date"
      }
    },
    {
      "type": "answer",
      "content": {
        "$regex": "owner"
      }
    },
    {
      "type": "answer",
      "content": {
        "$regex": "consequence|if nothing"
      }
    }
  ],
  "forbidden_events": [
